AQ_APP_NAME=Alpha Quantum
AQ_APP_VERSION=1.0.0
AQ_ENV=development
AQ_LOG_LEVEL=INFO
AQ_ALLOW_ALL_CORS=false
AQ_CORS_ORIGINS=http://127.0.0.1:8000
AQ_CORS_ALLOW_CREDENTIALS=false
AQ_DATABASE_PATH=alpha_quantum.db
AQ_JWT_SECRET=change-this-secret
AQ_ACCESS_TOKEN_EXPIRE_MINUTES=120
AQ_ENABLE_DEMO_USERS=true
AQ_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AQ_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AQ_AUTH_RATE_LIMIT_BACKEND=memory
AQ_AUTH_RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
AQ_AUTH_RATE_LIMIT_FAIL_OPEN=true
AQ_AUTH_USERS=ops:ops-pass:admin,analyst:analyst-pass:viewer
AQ_CONNECTOR_WORKER_ENABLED=false
AQ_CONNECTOR_WORKER_POLL_INTERVAL_SECONDS=15
AQ_CONNECTOR_WORKER_RETRY_BACKOFF_SECONDS=60
AQ_CONNECTOR_WORKER_MAX_RETRIES=3
AQ_CONNECTOR_WORKER_LEADER_LOCK_ENABLED=true
AQ_CONNECTOR_WORKER_LEASE_SECONDS=30
AQ_CONNECTOR_WORKER_HEARTBEAT_SECONDS=10
AQ_RUN_STAGING_REDIS_E2E=false
AQ_RUN_STAGING_REDIS_CHAOS=false
AQ_STAGING_REDIS_URL=redis://127.0.0.1:6379/0
AQ_TOXIPROXY_URL=http://127.0.0.1:8474
AQ_CHAOS_REDIS_PROXY_NAME=aq_redis
AQ_CHAOS_REDIS_PROXY_LISTEN=0.0.0.0:8666
AQ_CHAOS_REDIS_UPSTREAM=127.0.0.1:6379
AQ_CHAOS_REDIS_PROXY_URL=redis://127.0.0.1:8666/0
AQ_CHAOS_REDIS_SOCKET_TIMEOUT_SECONDS=1.0
AQ_MARKET_OFFLINE=false
AQ_MACRO_OFFLINE=false
AQ_WEB_OFFLINE=false
